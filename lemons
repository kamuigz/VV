        Menu._menu_key = keyName
        Menu:Notification("Menu key set to " .. keyName, 3)
    end
end)

miscSec:Button("Use RightControl", function()
    Menu._overwrite_menu_key = true
    Menu._menu_key = "rctrl"
    pcall(function() menuKeyToggle:Set(true) end)
    pcall(function() menuKeyBind:Set("rctrl", "Hold") end)
    Menu:Notification("Menu key set to RightControl", 3)
end)

