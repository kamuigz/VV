--// Automation workers
--// Loops are created only after their toggle is enabled, then cancelled on disable.
local stats = { buys = 0, upgrades = 0, fruit = 0, rebirths = 0, evolves = 0 }

local autoTokens = {}
local activeAutos = {}

local function isAutoActive(name)
    return activeAutos[name] == true
end

local function stopAuto(name)
    autoTokens[name] = (autoTokens[name] or 0) + 1
    activeAutos[name] = false
end

local function startAuto(name, delaySeconds, callback)
    stopAuto(name)
    autoTokens[name] = (autoTokens[name] or 0) + 1
    local token = autoTokens[name]
    activeAutos[name] = true

    spawn(function()
        while activeAutos[name] == true and autoTokens[name] == token do
            pcall(callback)
            wait(delaySeconds)
        end
    end)
end

local function setAuto(name, enabled, delaySeconds, callback)
    if enabled then
        startAuto(name, delaySeconds, callback)
    else
        stopAuto(name)
    end
end

--// AUTO BUY
-- Pure teleport mode. No remotes: scans local player's tycoon -> Purchases -> buttons folders.
-- Filters by affordability so it buys the $1 starter button before expensive future buttons.
local buyQueue = {}
local buyIndex = 1
local lastBuyScan = 0

local AUTO_NUM_SCALE = {
    thousand=1e3, million=1e6, billion=1e9, trillion=1e12,
    quadrillion=1e15, quintillion=1e18, sextillion=1e21, septillion=1e24,
    octillion=1e27, nonillion=1e30, decillion=1e33, undecillion=1e36,
    duodecillion=1e39, tredecillion=1e42, quattuordecillion=1e45,
    quindecillion=1e48, sexdecillion=1e51, septendecillion=1e54,
    octodecillion=1e57, novemdecillion=1e60, vigintillion=1e63,
    k=1e3, m=1e6, b=1e9, t=1e12, qd=1e15, qn=1e18,
    sx=1e21, sp=1e24, oc=1e27, no=1e30, dc=1e33,
}

local function getHRP()
    local char = LocalPlayer.Character
    return char and char:FindFirstChild("HumanoidRootPart")
end

local function safeAttr(obj, attrName)
    local value = nil
    pcall(function()
        value = obj:GetAttribute(attrName)
    end)
    return value
end

local function lowerName(obj)
    return string.lower(tostring(obj and obj.Name or ""))
end

local function parseAutoNumber(value)
    if value == nil then return nil end
    if type(value) == "number" then return value end

    local text = tostring(value):gsub(",", ""):lower()
    text = text:gsub("%$", "")
    local compact = text:gsub("%s+", "")

    local num, suffix = compact:match("([%d%.]+)([a-z]+)")
    if not num then
        num = compact:match("[%d%.]+")
    end

    local amount = num and tonumber(num)
    if not amount then return nil end

    if suffix and AUTO_NUM_SCALE[suffix] then
        return amount * AUTO_NUM_SCALE[suffix]
    end

    for word, scale in next, AUTO_NUM_SCALE do
        if #word > 1 and string.find(text, word, 1, true) then
            return amount * scale
        end
    end

    return amount
end

local function getCashValue()
    local leaderstats = LocalPlayer and LocalPlayer:FindFirstChild("leaderstats")
    local cash = leaderstats and leaderstats:FindFirstChild("Cash")
    if cash then
        return parseAutoNumber(cash.Value)
    end
    return nil
end

local function isButtonsFolder(obj)
    local name = lowerName(obj)
    return name == "buttons" or name == "button" or string.find(name, "buttons", 1, true) ~= nil
end

local function isPurchasedObject(obj)
    local cur = obj
    while cur and cur ~= userTycoon do
        if safeAttr(cur, "Purchased") == true then
            return true
        end
        cur = cur.Parent
    end
    return false
end

local function isHiddenObject(obj)
    local cur = obj
    while cur and cur ~= userTycoon do
        local shown = safeAttr(cur, "Shown")
        if shown == false then
            return true
        end
        cur = cur.Parent
    end
    return false
end

local function isVisiblePart(part)
    local visible = true
    pcall(function()
        if part.Transparency >= 0.98 then
            visible = false
        end
    end)
    return visible
end

local function isGreenBuyPart(part)
    local green = false
    pcall(function()
        -- Affordable pads in this tycoon show as bright green. Expensive locked pads
        -- are grey/orange, so color is a better Matcha-safe signal than hidden remotes.
        local c = part.Color
        green = c.G >= 0.65 and c.R <= 0.55 and c.B <= 0.55
    end)
    return green
end

local function scoreButtonPart(part)
    local name = lowerName(part)
    local score = 0

    if string.find(name, "button", 1, true) then score = score + 120 end
    if string.find(name, "pad", 1, true) then score = score + 110 end
    if string.find(name, "buy", 1, true) then score = score + 100 end
    if string.find(name, "purchase", 1, true) then score = score + 90 end
    if string.find(name, "touch", 1, true) then score = score + 80 end
    if string.find(name, "hitbox", 1, true) then score = score + 70 end

    if isGreenBuyPart(part) then
        score = score + 1000
    end

    pcall(function()
        score = score + math.min(part.Size.X * part.Size.Z, 60)
    end)

    return score
end

local function getButtonParts(root, requireGreen)
    local parts = {}
    if not root then return parts end

    if root:IsA("BasePart") and isVisiblePart(root) then
        if (not requireGreen) or isGreenBuyPart(root) then
            parts[#parts + 1] = { part = root, score = scoreButtonPart(root) }
        end
    end

    for _, obj in next, root:GetDescendants() do
        if obj:IsA("BasePart") and isVisiblePart(obj) then
            if (not requireGreen) or isGreenBuyPart(obj) then
                parts[#parts + 1] = { part = obj, score = scoreButtonPart(obj) }
            end
        end
    end

    table.sort(parts, function(a, b)
        return a.score > b.score
    end)

    return parts
end

local function readObjectText(obj)
    local text = nil
    pcall(function()
        if type(obj.Text) == "string" and obj.Text ~= "" then
            text = obj.Text
        end
    end)
    return text
end

local function getButtonCost(root)
    if not root then return nil end

    local attrNames = {"Price", "Cost", "Amount", "Cash", "Money", "Value", "RequiredCash"}
    local cur = root
    while cur and cur ~= userTycoon do
        for _, attrName in next, attrNames do
            local parsed = parseAutoNumber(safeAttr(cur, attrName))
            if parsed then return parsed end
        end
        cur = cur.Parent
    end

    local texts = {}
    local rootText = readObjectText(root)
    if rootText then texts[#texts + 1] = rootText end

    for _, obj in next, root:GetDescendants() do
        local valueText = nil
        pcall(function()
            if obj.Value ~= nil then
                valueText = tostring(obj.Value)
            end
        end)
        if valueText then
            local lname = lowerName(obj)
            if string.find(lname, "price", 1, true)
                or string.find(lname, "cost", 1, true)
                or string.find(lname, "cash", 1, true)
                or string.find(lname, "money", 1, true) then
                local parsedValue = parseAutoNumber(valueText)
                if parsedValue then return parsedValue end
            end
        end

        local textValue = readObjectText(obj)
        if textValue then
            texts[#texts + 1] = textValue
        end
    end

    if #texts > 0 then
        return parseAutoNumber(table.concat(texts, " "))
    end

    return nil
end

local function isAvailableButtonRoot(root)
    if not root or not root.Parent then return false end
    if isPurchasedObject(root) then return false end
    if isHiddenObject(root) then return false end

    local shown = safeAttr(root, "Shown")
    local purchased = safeAttr(root, "Purchased")
    if shown == false or purchased == true then return false end

    local parts = getButtonParts(root, true)
    return #parts > 0
end

local function queueCandidate(list, root, cashValue)
    if not isAvailableButtonRoot(root) then return end

    local cost = getButtonCost(root)
    if cost and cashValue and cost > cashValue + 0.001 then
        return
    end

    list[#list + 1] = {
        root = root,
        cost = cost or math.huge,
    }
end

local function refreshBuyQueue()
    buyQueue = {}
    buyIndex = 1
    lastBuyScan = tick()

    if not userTycoon then
        findTycoon()
        return
    end

    local purchases = userTycoon:FindFirstChild("Purchases")
    if not purchases then return end

    local cashValue = getCashValue()
    local candidates = {}

    for _, obj in next, purchases:GetDescendants() do
        if isButtonsFolder(obj) then
            for _, buttonRoot in next, obj:GetChildren() do
                queueCandidate(candidates, buttonRoot, cashValue)
            end
        end
    end

    table.sort(candidates, function(a, b)
        if a.cost == b.cost then
            return tostring(a.root.Name) < tostring(b.root.Name)
        end
        return a.cost < b.cost
    end)

    buyQueue = candidates
end

local function standOnPart(part, holdSeconds)
    local hrp = getHRP()
    if not (hrp and part) then return false end

    local targetCFrame = nil
    pcall(function()
        local yOffset = math.max(3, (part.Size.Y / 2) + 3)
        targetCFrame = part.CFrame + Vector3.new(0, yOffset, 0)
    end)

    if not targetCFrame then
        pcall(function()
            targetCFrame = CFrame.new(part.Position + Vector3.new(0, 4, 0))
        end)
    end

    if not targetCFrame then return false end

    local untilTime = tick() + holdSeconds
    while tick() < untilTime and isAutoActive("AutoBuy") do
        pcall(function()
            hrp.CFrame = targetCFrame
            hrp.AssemblyLinearVelocity = Vector3.new(0, 0, 0)
        end)

        if type(firetouchinterest) == "function" then
            pcall(function()
                firetouchinterest(hrp, part, 0)
                firetouchinterest(hrp, part, 1)
            end)
        end

        wait(0.08)
    end

    return true
end

local function buyButtonByTeleport(buttonRoot)
    if not isAvailableButtonRoot(buttonRoot) then return false end

    local cost = getButtonCost(buttonRoot)
    local cashValue = getCashValue()
    if cost and cashValue and cost > cashValue + 0.001 then
        return false
    end

    local parts = getButtonParts(buttonRoot, true)
    if #parts == 0 then return false end

    local maxParts = math.min(#parts, 4)
    for i = 1, maxParts do
        if not isAutoActive("AutoBuy") then break end
        standOnPart(parts[i].part, 0.35)
        wait(0.1)
    end

    stats.buys = stats.buys + 1
    return true
end

local function autoBuyPass()
    if tick() - lastBuyScan > 0.75 or buyIndex > #buyQueue then
        refreshBuyQueue()
    end

    local item = buyQueue[buyIndex]
    buyIndex = buyIndex + 1
    if not item then return end

    buyButtonByTeleport(item.root)
    wait(0.25)
end
--// AUTO UPGRADE
local upgradeRemotes = {}
local upgradeLevel = {}
local lastUpgradeScan = 0

local function refreshUpgradeRemotes()
    upgradeRemotes = {}
    upgradeLevel = {}
    if not userTycoon then return end

    local purchases = userTycoon:FindFirstChild("Purchases")
    if not purchases then return end

    for _, obj in next, purchases:GetDescendants() do
        if obj:IsA("RemoteFunction") and obj.Name == "Upgrade" then
            upgradeRemotes[#upgradeRemotes + 1] = obj
        end
    end
end

local function autoUpgradePass()
    if not userTycoon then
        findTycoon()
        return
    end

    if tick() - lastUpgradeScan > 3 then
        refreshUpgradeRemotes()
        lastUpgradeScan = tick()
    end

    for _, remote in next, upgradeRemotes do
        if remote.Parent then
            local lvl = (upgradeLevel[remote] or 0) + 1
            while lvl <= 100 do
                local ok, res = pcall(function()
                    return remote:InvokeServer(lvl)
                end)
                if (not ok) or res == false then break end
                upgradeLevel[remote] = lvl
                stats.upgrades = stats.upgrades + 1
                lvl = lvl + 1
            end
        end
    end
end

