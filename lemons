local userTycoon = nil

local function findTycoon()
    local localName = LocalPlayer and LocalPlayer.Name
    if not localName then return end
    for _, v in next, workspace:GetChildren() do
        if v.Name:match("Tycoon%d") then
            local owner = v:FindFirstChild("Owner")
            if owner and owner.Value then
                pcall(function()
                    if owner.Value.Name == localName then
                        userTycoon = v
                    end
                end)
            end
        end
        if userTycoon then break end
    end
end

